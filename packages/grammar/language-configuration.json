{
	"comments": {
		"lineComment": "#"
	},
	"brackets": [["{", "}"]],
	"autoClosingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "\"", "close": "\"", "notIn": ["string"] },
		{ "open": "^", "close": "^", "notIn": ["string", "comment"] },
		{ "open": "%", "close": "%", "notIn": ["string", "comment"] }
	],
	"surroundingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "\"", "close": "\"" },
		{ "open": "^", "close": "^" },
		{ "open": "%", "close": "%" }
	],
	"folding": {
		"markers": {
			"start": "^\\s*#\\s*region",
			"end": "^\\s*#\\s*endregion"
		}
	},
	"wordPattern": "[a-zA-Z_]\\w*"
}
